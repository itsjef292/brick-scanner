<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Monthly Brick Tap retirement-data refresh (launchd LaunchAgent).

  This is a TEMPLATE: __PROJECT_DIR__ is filled in with the real project path
  by ./install_agents.sh at install time, so it works on any machine/user/path.

  Install (from the project dir):
    ./install_agents.sh          # substitutes paths, copies to ~/Library/LaunchAgents, loads all agents

  Run once now to test:
    launchctl start com.brickscanner.retirement-refresh

  Uninstall:
    launchctl unload ~/Library/LaunchAgents/com.brickscanner.retirement-refresh.plist

  Runs on the 5th of every month at 06:00 local time — the Brick Tap sheet is
  updated near the start of each month ("Last update: June 3" etc.), so the 5th
  catches it. If the Mac is asleep then, launchd runs it at the next wake.
  Rebuilds retirement_sets.json in place; the app picks it up via mtime check.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.brickscanner.retirement-refresh</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__PROJECT_DIR__/refresh_retirement.sh</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Day</key>
        <integer>5</integer>
        <key>Hour</key>
        <integer>6</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>__PROJECT_DIR__/retirement_refresh.log</string>
    <key>StandardErrorPath</key>
    <string>__PROJECT_DIR__/retirement_refresh.log</string>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
