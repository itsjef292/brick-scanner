<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Daily BrickLink price refresh for the My Minifigs collection (launchd LaunchAgent).

  This is a TEMPLATE: __PROJECT_DIR__ is filled in with the real project path
  by ./install_agents.sh at install time, so it works on any machine/user/path.

  Install (from the project dir):
    ./install_agents.sh          # substitutes paths, copies to ~/Library/LaunchAgents, loads all agents

  Run once now to test:
    launchctl start com.brickscanner.minifig-prices

  Uninstall:
    launchctl unload ~/Library/LaunchAgents/com.brickscanner.minifig-prices.plist

  Runs every day at 05:00 local time. If the Mac is asleep then, launchd runs it
  at the next wake. LOCAL-ONLY (does nothing useful on Render). Logs go to
  minifig_prices.log; launchd captures stray stdout/stderr in
  minifig_prices.launchd.log.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.brickscanner.minifig-prices</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__PROJECT_DIR__/refresh_minifig_prices.sh</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>5</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>__PROJECT_DIR__/minifig_prices.launchd.log</string>
    <key>StandardErrorPath</key>
    <string>__PROJECT_DIR__/minifig_prices.launchd.log</string>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
