# Copy this file to .env and fill in your real credentials.
# .env is git-ignored — never commit real values. On Render, set these in the
# dashboard (Environment tab) instead; render.yaml declares them with sync:false.

# Rebrickable — account → Settings → API
REBRICKABLE_API_KEY=your_api_key_here
REBRICKABLE_USER_TOKEN=your_user_token_here

# BrickLink — My Account → API → Access Tokens (OAuth1)
BL_CONSUMER_KEY=your_consumer_key_here
BL_CONSUMER_SECRET=your_consumer_secret_here
BL_TOKEN=your_token_here
BL_TOKEN_SECRET=your_token_secret_here
