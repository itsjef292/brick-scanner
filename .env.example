# Copy this file to .env and fill in your real credentials.
# .env is git-ignored — never commit real values. On Render, set these in the
# dashboard (Environment tab) instead; render.yaml declares them with sync:false.

# Rebrickable — account → Settings → API
REBRICKABLE_API_KEY=your_api_key_here
REBRICKABLE_USER_TOKEN=your_user_token_here

# BrickLink — My Account → API → Access Tokens (OAuth1)
BL_CONSUMER_KEY=your_consumer_key_here
BL_CONSUMER_SECRET=your_consumer_secret_here
BL_TOKEN=your_token_here
BL_TOKEN_SECRET=your_token_secret_here

# App login. Set APP_PASSWORD to gate the whole app behind a sign-in page so an
# exposed URL can't be tampered with; leave it unset to run open (local dev).
# APP_SECRET_KEY signs the session cookie — set a long random value and keep it
# STABLE (REQUIRED on Render; locally a random key is auto-persisted if unset).
APP_PASSWORD=your_app_password_here
APP_SECRET_KEY=long_random_string_here

# Optional Face ID / passkey sign-in (WebAuthn). Don't hand-edit: after signing
# in, tap the key icon in the header to register a passkey, then paste the value
# it gives you here / into the Render dashboard so it survives deploys (Render's
# FS is ephemeral). Stores PUBLIC keys only — not a secret.
# PASSKEY_CREDENTIALS=[]

# Optional minifig "Authenticity Check" (Claude vision). Get a key at
# console.anthropic.com → API Keys. Unset = the feature returns 503 / the button
# reports "not configured". Billed per use (~$0.10/check) — it's opt-in, not per scan.
ANTHROPIC_API_KEY=sk-ant-...
