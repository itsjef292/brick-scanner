.env
.claude/
__pycache__/
*.pyc
.DS_Store

# Offline catalog: Rebrickable CSV dump + generated SQLite DB (local dev only,
# ~330MB total). Rebuild locally with: python3 build_brick_db.py
Brick Parts/
brick_parts.db
brick_parts.db.new*
templates/index.html.bak

# Daily catalog-refresh runtime artifacts (local dev only)
.catalog_manifest.json
.catalog_changes.json
.catalog_last_checked
catalog_refresh.log
catalog_refresh.launchd.log

# Flask app log (launchd autostart agent, local dev only)
app.log

# Owned-set purchase metadata + local minifig collection (local dev only)
.set_meta.json
.set_meta.json.tmp
.minifig_collection.json
.minifig_collection.json.tmp
.cmf_captured.json
.cmf_captured.json.tmp

# Daily minifig price-refresh logs (local dev only)
minifig_prices.log
minifig_prices.launchd.log

# Native iOS shell (Capacitor) — build/dependency artifacts. The committed
# source is native/package.json + native/capacitor.config.json + native/www/.
# The ios/ project + node_modules are generated on the build Mac (see BUILD_IOS.md).
native/node_modules/
native/ios/
native/.DS_Store
native/package-lock.json
